{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm publish*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-publish.sh",
            "timeout": 30,
            "statusMessage": "Running pre-publish checks..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm publish*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-publish.sh",
            "async": true,
            "statusMessage": "Publishing to GitHub and sending notification..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm version*)",
            "command": "jq -n '{\"systemMessage\": \"Version bumped. Remember to run: npm run build && npm publish --access public\"}'",
            "statusMessage": "Version bumped"
          }
        ]
      }
    ]
  }
}
